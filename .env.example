# CCAAScraper — usbasket CCAA → Hoop Central
HOOP_CENTRAL_API_URL=https://hoopcentral-50-production.up.railway.app
# Local dev alternative:
# HOOP_CENTRAL_API_URL=http://localhost:3001

# Optional — only needed if INGEST_API_KEY is set on the server
INGEST_API_KEY=

# usbasket.com subscription login (optional if public pages suffice)
USBASKET_EMAIL=
USBASKET_PASSWORD=
# Or paste a full Cookie header after manual login:
# USBASKET_COOKIE=

# Request pacing (ms) — backfill caps at 400ms/player, 800ms/index season
SCRAPE_REQUEST_DELAY_MS=800
SCRAPE_INDEX_DELAY_MS=1500

# Global player ID discovery (npm run discover:global) uses the same usbasket login.
# Output: usbasket-global-player-ids.cache.json, usbasket-global-player-slugs.cache.json

# Career profile backfill (npm run career:backfill) reads the global slug cache,
# fetches each usbasket profile once, routes all career lines to Hoop Central leagues.
# Use --enrich-existing to only fill players already on the site (NBA/G League/DOB match).
