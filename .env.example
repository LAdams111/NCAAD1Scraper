# Hoop Central API (required)
HOOP_CENTRAL_API_URL=https://hoopcentral-50-production.up.railway.app
# Local dev alternative:
# HOOP_CENTRAL_API_URL=http://localhost:3001

# Optional — only needed if INGEST_API_KEY is set on the server
INGEST_API_KEY=

# usbasket.com subscription login (optional if public pages suffice)
USBASKET_EMAIL=
USBASKET_PASSWORD=
# Or paste a full Cookie header after manual login:
# USBASKET_COOKIE=

# Request pacing (ms) — usbasket is unknown; start conservative
SCRAPE_REQUEST_DELAY_MS=12000
SCRAPE_INDEX_DELAY_MS=15000
