{
  "name": "scraper-ccaa",
  "version": "1.0.0",
  "description": "CCAA men's basketball player-season scraper for Hoop Central via usbasket.com",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/test/*.test.js",
    "test:build": "npm run build && npm test",
    "start": "node dist/index.js",
    "scrape": "node dist/index.js",
    "scrape:backfill": "node dist/index.js --backfill",
    "scrape:backfill:shard0": "node dist/index.js --backfill --shard 0/2",
    "scrape:backfill:shard1": "node dist/index.js --backfill --shard 1/2",
    "scrape:backfill:shard0:4": "node dist/index.js --backfill --shard 0/4",
    "scrape:backfill:shard1:4": "node dist/index.js --backfill --shard 1/4",
    "scrape:backfill:shard2:4": "node dist/index.js --backfill --shard 2/4",
    "scrape:backfill:shard3:4": "node dist/index.js --backfill --shard 3/4",
    "scrape:dry-run": "node dist/index.js --dry-run",
    "repair:d2-links:scan": "node scripts/repair-d2-links.mjs --scan --fetch-dob",
    "repair:d2-links:apply": "node scripts/repair-d2-links.mjs --apply",
    "repair:ccaa-profiles": "node scripts/repair-ccaa-profiles.mjs",
    "audit:ccaa-missing-career": "node scripts/audit-ccaa-missing-career.mjs",
    "repair:ccaa-missing-career": "node scripts/repair-ccaa-missing-career.mjs",
    "patch:ccaa-names": "node scripts/patch-ccaa-cache-names.mjs",
    "generate:ccaa-team-aliases": "node scripts/generate-ccaa-team-aliases.mjs",
    "scrape:discover": "node dist/index.js --discover-only --shard 0/4",
    "discover:global": "node dist/discover/index.js --include-eurobasket",
    "discover:global:shard0": "node dist/discover/index.js --include-eurobasket --shard 0/4 --resume",
    "discover:global:shard1": "node dist/discover/index.js --include-eurobasket --shard 1/4 --resume",
    "discover:global:shard2": "node dist/discover/index.js --include-eurobasket --shard 2/4 --resume",
    "discover:global:shard3": "node dist/discover/index.js --include-eurobasket --shard 3/4 --resume",
    "discover:global:launch": "bash scripts/start-global-discovery.sh",
    "discover:global:merge": "node scripts/merge-global-discovery.mjs",
    "discover:global:supplement": "bash scripts/start-global-discovery-supplement.sh",
    "discover:global:rescan-pages": "node dist/discover/index.js --include-eurobasket --rescan-completed --resume",
    "career:backfill": "node dist/career/index.js --backfill",
    "career:dry-run": "node dist/career/index.js --dry-run --backfill",
    "career:enrich": "node dist/career/index.js --backfill --enrich-existing",
    "career:backfill:shard0": "node dist/career/index.js --backfill --shard 0/4 --resume",
    "career:backfill:shard1": "node dist/career/index.js --backfill --shard 1/4 --resume",
    "career:backfill:shard2": "node dist/career/index.js --backfill --shard 2/4 --resume",
    "career:backfill:shard3": "node dist/career/index.js --backfill --shard 3/4 --resume",
    "career:backfill:launch": "bash scripts/start-career-backfill.sh"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
